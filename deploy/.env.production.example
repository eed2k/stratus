# =============================================================================
# Stratus Weather Server — Production Environment Variables
# =============================================================================
# Copy this file to /opt/stratus/.env and fill in your values.
#
# REQUIRED variables are marked [REQUIRED]
# =============================================================================

# ── Domain ──────────────────────────────────────────────────────────────
# [REQUIRED] Your primary domain (used by Traefik for routing + SSL)
DOMAIN=stratusweather.co.za

# [REQUIRED] Email for Let's Encrypt certificate notifications
ACME_EMAIL=your-email@example.com

# ── Database ────────────────────────────────────────────────────────────
# [REQUIRED] Vultr Managed PostgreSQL connection string
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://dbuser:XXXXX@vultr-db-host:5432/stratus?sslmode=require

# ── Authentication ──────────────────────────────────────────────────────
# [REQUIRED] JWT signing secret — generate with: openssl rand -hex 32
CLIENT_JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# [REQUIRED] Initial admin account
STRATUS_ADMIN_EMAIL=admin@stratusweather.co.za
STRATUS_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
STRATUS_ADMIN_NAME=Admin

# ── Dropbox Sync ────────────────────────────────────────────────────────
# For stations that upload data via cellular modem to Dropbox
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
DROPBOX_FOLDER_PATH=

# ── MailerSend Email ────────────────────────────────────────────────────
# Free tier: 3,000 emails/month — https://www.mailersend.com
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=noreply@stratusweather.co.za
MAILERSEND_FROM_NAME=Stratus Weather
MAILERSEND_ALERTS_EMAIL=alerts@stratusweather.co.za

# ── Windy Map ───────────────────────────────────────────────────────────
WINDY_API_KEY=
WINDY_MAP_API_KEY=

# ── Public URL ──────────────────────────────────────────────────────────
APP_BASE_URL=https://stratusweather.co.za

# ── Staleness Monitor ──────────────────────────────────────────────────
# Check interval (ms) — default 15 minutes
STALENESS_CHECK_INTERVAL=900000
# Threshold before alert (ms) — default 2 hours
STALENESS_THRESHOLD=7200000
# Cooldown between re-alerts (ms) — default 6 hours
STALENESS_COOLDOWN=21600000

# ── Local PostgreSQL (only if using docker-compose.yml with local DB) ──
# POSTGRES_PASSWORD=change_me
