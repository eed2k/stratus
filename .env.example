# ============================================
# STRATUS WEATHER STATION - ENVIRONMENT CONFIGURATION
# ============================================
# 
# PRODUCTION DEPLOYMENT REQUIREMENTS:
# For production deployment, administrators MUST set these environment variables:
#
# 1. CLIENT_JWT_SECRET - Required, generate with: openssl rand -hex 32
# 2. STRATUS_ADMIN_EMAIL - Required for admin account creation
# 3. STRATUS_ADMIN_PASSWORD - Required, use a strong password (8+ characters)
# 4. NODE_ENV=production - Required to enable production optimizations
#
# ============================================

# Database Configuration
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/stratus

# Server Configuration
PORT=5000
NODE_ENV=development

# ============================================
# REQUIRED FOR PRODUCTION
# ============================================

# Required - Generate a strong 32+ character secret
# Generate with: openssl rand -hex 32
CLIENT_JWT_SECRET=<generate with: openssl rand -hex 32>

# Required - Admin account credentials
# Use a strong password: minimum 8 characters, mix of letters, numbers, and symbols
STRATUS_ADMIN_EMAIL=your-admin@domain.com
STRATUS_ADMIN_PASSWORD=<strong-password-here>
STRATUS_ADMIN_NAME=Admin User

# Required - Set to production for deployment
NODE_ENV=production

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# Demo Mode (bypasses authentication for testing)
# Set to 'true' for demo/testing, 'false' for production
VITE_DEMO_MODE=false

# Optional: Logging Level
# Options: error, warn, info, debug
LOG_LEVEL=info

# Optional: Campbell Scientific Configuration
# Default PakBus timeout in milliseconds
PAKBUS_TIMEOUT=30000

# Default reconnection interval in seconds
RECONNECT_INTERVAL=30

# Maximum reconnection attempts
MAX_RECONNECT_ATTEMPTS=10

# Optional: Email Configuration (MailerSend for alarm & staleness notifications)
# Sign up at https://www.mailersend.com (free tier: 3,000 emails/month)
# 1. Add and verify your domain in Domains
# 2. Create an API token in API Tokens
# MAILERSEND_API_KEY=your_api_token
# MAILERSEND_FROM_EMAIL=noreply@yourdomain.com
# MAILERSEND_FROM_NAME=Stratus Weather
# MAILERSEND_ALERTS_EMAIL=alerts@yourdomain.com

# Optional: Public URL (used in email links and share links)
# APP_BASE_URL=https://your-domain.com

# Optional: Staleness Monitor Configuration
# Check interval in milliseconds (default: 900000 = 15 minutes)
# STALENESS_CHECK_INTERVAL=900000
# Staleness threshold in milliseconds (default: 7200000 = 2 hours)
# STALENESS_THRESHOLD=7200000
# Alert cooldown in milliseconds (default: 21600000 = 6 hours)
# STALENESS_COOLDOWN=21600000

# Optional: SMS Configuration (for alarm notifications)
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# Optional: File Storage (for calibration certificates, photos)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=stratus-uploads

# Optional: Redis (for caching and session management)
# REDIS_URL=redis://localhost:6379

# Optional: Dropbox Integration (for file-based data import)
# Create app at: https://www.dropbox.com/developers/apps
# DROPBOX_APP_KEY=your_app_key
# DROPBOX_APP_SECRET=your_app_secret
# DROPBOX_REFRESH_TOKEN=your_refresh_token
