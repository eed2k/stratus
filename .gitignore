# ─────────────────────────────────────────────
# Stratus .gitignore
# ─────────────────────────────────────────────

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Web build outputs ──
dist/
build/
tmp_dist/
.next/
out/
output/

# Compiled shared files (generated from .ts sources)
shared/*.js
shared/*.d.ts

# ── Environment / secrets ──
.env
.env.local
.env.*.local
.env.production.local
deploy/.env.production
.neon
.mailmap

# ── IDE / editor ──
.vscode/
.idea/
*.swp
*.swo
*~
.#*

# ── OS files ──
.DS_Store
Thumbs.db

# ── Logs ──
logs/
*.log

# ── Temp / cache ──
temp/
tmp/
.cache/

# ── Database files ──
*.db
*.sqlite

# ── Docker ──
docker-compose.override.yml

# ── Data files (samples live in demo_data/ only) ──
*.dat
*.backup
*.tdf
*.xlsx
*.emf
!demo_data/

# ── CRBasic programs (keep in examples/crbasic/ only) ──
*.CR300
*.CRB
*.cr300

# ── Archives / build bundles ──
*.tar.gz
*.tar
*.zip

# ── Images (tracked assets live in assets/) ──
*.png

# ── Build logs ──
build.log

# ── Sensitive / ad-hoc root-level scripts ──
test_neon.js
check_timestamps.js
del_stations.js
set_server.js
fix_encoding.js
check_mppt_tmp.js
check_mppt_api.py
mppt_test.sql
update_coords.sql
scripts/login.json

# ── .NET Desktop build artifacts ──
desktop/Stratus.Desktop/bin/
desktop/Stratus.Desktop/obj/
desktop/Stratus.Desktop/publish/
desktop/Stratus.Desktop/*.dll
desktop/Stratus.Desktop/*.zip
desktop/publish/
*.user
*.suo

# ── Release binaries (too large for GitHub) ──
release/
*.exe
*.blockmap
*.nupkg
windrose-main/
