modules = ["nodejs-20", "web", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx server/index.ts"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 24678
externalPort = 3001

[deployment]
deploymentTarget = "autoscale"
run = ["npx", "tsx", "server/index.ts"]
build = ["npm", "run", "build:client"]

[userenv]

[userenv.shared]
VITE_NETLIFY_SITE_URL = "https://stratusweather1.netlify.app"
VITE_DEMO_MODE = "true"
