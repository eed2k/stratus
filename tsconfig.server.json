{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist/server",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2020"],
    "declaration": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "noImplicitAny": false
  },
  "include": ["server/**/*"],
  "exclude": ["node_modules", "dist", "shared"]
}
