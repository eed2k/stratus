{
  "Server": {
    "BaseUrl": "https://stratus.itronics.co.za",
    "ApiTimeout": 30
  },
  "Database": {
    "ConnectionString": "",
    "UseDirect": false
  },
  "License": {
    "Key": "",
    "Validated": false
  },
  "DataAcquisition": {
    "PollIntervalSeconds": 60,
    "RetryAttempts": 3,
    "RetryDelayMs": 5000,
    "MaxDataPoints": 10000
  },
  "Export": {
    "DefaultFormat": "CSV",
    "DefaultDirectory": "%USERPROFILE%\\Documents\\Stratus",
    "IncludeHeaders": true,
    "TimestampFormat": "yyyy-MM-dd HH:mm:ss"
  },
  "Logging": {
    "Level": "Information",
    "LogDirectory": "%APPDATA%\\Stratus\\Logs",
    "RetainDays": 30
  }
}
