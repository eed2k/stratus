<Window x:Class="Stratus.Desktop.Views.DatabaseConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connect to PostgreSQL Database" 
        Height="280" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource StratusWindow}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Database Connection" Style="{StaticResource SectionHeader}"/>
        
        <TextBlock Grid.Row="1" Text="Enter a PostgreSQL connection string to connect directly to the database." 
                   TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
        
        <TextBlock Grid.Row="2" Text="Connection String:" FontSize="11" Margin="0,0,0,4"/>
        <TextBox Grid.Row="3" x:Name="ConnectionStringBox" 
                 Style="{StaticResource StratusTextBox}" 
                 Text="postgresql://user:password@host:5432/dbname?sslmode=require"
                 Height="60" TextWrapping="Wrap" AcceptsReturn="False"
                 VerticalScrollBarVisibility="Auto"/>

        <TextBlock Grid.Row="4" x:Name="StatusText" Text="" FontSize="11" 
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0"
                   VerticalAlignment="Top"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Test Connection" Style="{StaticResource SecondaryButton}" 
                    Click="TestConnection_Click" Margin="0,0,8,0"/>
            <Button Content="Connect" Style="{StaticResource PrimaryButton}" 
                    Click="Connect_Click" Margin="0,0,8,0"/>
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}" 
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
