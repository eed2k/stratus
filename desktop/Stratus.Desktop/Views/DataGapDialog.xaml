<Window x:Class="Stratus.Desktop.Views.DataGapDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Data Gap Analysis" Height="560" Width="750"
        WindowStartupLocation="CenterOwner"
        Background="#F0F4F8">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Data Gap Analysis &amp; Backfill" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="Detect temporal gaps in collected data and attempt to recover missing records."
                       Foreground="#64748B" Margin="0,2,0,8"/>
            <Rectangle Height="2" Fill="#2563EB"/>
        </StackPanel>

        <!-- Settings -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Expected interval:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#1E293B"/>
            <ComboBox Grid.Column="1" x:Name="IntervalCombo" Width="120" Padding="4,3">
                <ComboBoxItem Content="1 minute" Tag="1"/>
                <ComboBoxItem Content="5 minutes" Tag="5" IsSelected="True"/>
                <ComboBoxItem Content="10 minutes" Tag="10"/>
                <ComboBoxItem Content="15 minutes" Tag="15"/>
                <ComboBoxItem Content="30 minutes" Tag="30"/>
                <ComboBoxItem Content="1 hour" Tag="60"/>
            </ComboBox>
            <TextBlock Grid.Column="2" x:Name="StationText" Foreground="#64748B" FontSize="11" 
                       VerticalAlignment="Center" Margin="12,0,0,0"/>
            <Button Grid.Column="3" Content="Analyse" Padding="14,6" Click="Analyse_Click"
                    Background="#2563EB" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
        </Grid>

        <!-- Gap Grid -->
        <DataGrid Grid.Row="2" x:Name="GapGrid" Margin="0,10,0,0"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                  Background="White" BorderBrush="#CBD5E1" BorderThickness="1"
                  RowHeight="28" ColumnHeaderHeight="32">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1E293B"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Padding" Value="6,4"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="11"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Gap Start" Binding="{Binding Start, StringFormat=yyyy-MM-dd HH:mm}" Width="140"/>
                <DataGridTextColumn Header="Gap End" Binding="{Binding End, StringFormat=yyyy-MM-dd HH:mm}" Width="140"/>
                <DataGridTextColumn Header="Duration" Binding="{Binding Duration, StringFormat=hh\\:mm\\:ss}" Width="100"/>
                <DataGridTextColumn Header="Missed Records" Binding="{Binding MissedRecords}" Width="100"/>
                <DataGridTextColumn Header="Backfilled" Binding="{Binding BackfilledRecords}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Summary -->
        <Border Grid.Row="3" x:Name="SummaryPanel" Background="White" BorderBrush="#CBD5E1" 
                BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,8,0,0" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Total Records" FontSize="9" Foreground="#64748B"/>
                    <TextBlock x:Name="TotalRecordsText" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Gaps Found" FontSize="9" Foreground="#64748B"/>
                    <TextBlock x:Name="GapCountText" FontSize="16" FontWeight="Bold" Foreground="#DC2626"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Coverage" FontSize="9" Foreground="#64748B"/>
                    <TextBlock x:Name="CoverageText" FontSize="16" FontWeight="Bold" Foreground="#059669"/>
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="Status" FontSize="9" Foreground="#64748B"/>
                    <TextBlock x:Name="StatusText" FontSize="11" Foreground="#1E293B" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BackfillBtn" Content="Backfill from API" Padding="14,6" Margin="0,0,6,0" 
                    Click="Backfill_Click" IsEnabled="False"
                    Background="#059669" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
            <Button Content="Close" Padding="14,6" Click="Close_Click"
                    Background="#E2E8F0" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
