<Window x:Class="Stratus.Desktop.Views.QualityRulesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QC/QA Rule Configuration" Height="680" Width="920"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource StratusWindow}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Data Quality Control Rules" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Configure WMO-style range checks, rate-of-change limits, and stuck-sensor detection per parameter."
                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Rules DataGrid -->
        <DataGrid x:Name="RulesGrid" Grid.Row="1"
                  Style="{StaticResource StratusDataGrid}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserSortColumns="True"
                  SelectionMode="Single"
                  SelectionChanged="RulesGrid_SelectionChanged"
                  VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="On" Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}" Width="36"/>
                <DataGridTextColumn Header="Sensor" Binding="{Binding DisplayName}" Width="140" IsReadOnly="True"/>
                <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="55" IsReadOnly="True"/>
                <DataGridTextColumn Header="Min (Bad)" Binding="{Binding RangeMin, StringFormat='{}{0:F1}'}" Width="75"/>
                <DataGridTextColumn Header="Max (Bad)" Binding="{Binding RangeMax, StringFormat='{}{0:F1}'}" Width="75"/>
                <DataGridTextColumn Header="Min (Warn)" Binding="{Binding SuspectMin, StringFormat='{}{0:F1}'}" Width="80"/>
                <DataGridTextColumn Header="Max (Warn)" Binding="{Binding SuspectMax, StringFormat='{}{0:F1}'}" Width="80"/>
                <DataGridTextColumn Header="ΔRate (Warn)" Binding="{Binding MaxRateOfChange, StringFormat='{}{0:F1}'}" Width="85"/>
                <DataGridTextColumn Header="ΔRate (Bad)" Binding="{Binding MaxRateOfChangeBad, StringFormat='{}{0:F1}'}" Width="80"/>
                <DataGridTextColumn Header="Persist" Binding="{Binding PersistenceLimit}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Edit Panel -->
        <GroupBox Grid.Row="2" Header="Edit Selected Rule" Style="{StaticResource StratusGroupBox}" Margin="0,8,0,0" Padding="8">
            <Grid x:Name="EditPanel" IsEnabled="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Sensor + Range -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,6">
                    <TextBlock Text="Sensor" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox x:Name="SensorCombo" IsEnabled="False" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,6">
                    <TextBlock Text="Range Min (Bad)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox x:Name="TxtRangeMin" Style="{StaticResource StratusTextBox}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,8,6">
                    <TextBlock Text="Range Max (Bad)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox x:Name="TxtRangeMax" Style="{StaticResource StratusTextBox}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,0,6">
                    <TextBlock Text="Enabled" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <CheckBox x:Name="ChkEnabled" IsChecked="True" Margin="0,5,0,0" Content="Active"/>
                </StackPanel>

                <!-- Row 1: Suspect thresholds -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,6">
                    <TextBlock Text="Suspect Min" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox x:Name="TxtSuspectMin" Style="{StaticResource StratusTextBox}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,8,6">
                    <TextBlock Text="Suspect Max" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox x:Name="TxtSuspectMax" Style="{StaticResource StratusTextBox}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,8,6">
                    <TextBlock Text="Max ΔRate (Warn)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox x:Name="TxtMaxRate" Style="{StaticResource StratusTextBox}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,0,0,6">
                    <TextBlock Text="Max ΔRate (Bad)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox x:Name="TxtMaxRateBad" Style="{StaticResource StratusTextBox}" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Row 2: Persistence + Actions -->
                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Persistence Limit" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox x:Name="TxtPersistence" Style="{StaticResource StratusTextBox}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" VerticalAlignment="Bottom" Margin="0,0,8,0">
                    <Button Content="Apply Changes" Style="{StaticResource PrimaryButton}" Padding="12,6" Click="ApplyRule_Click"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="2" VerticalAlignment="Bottom" Margin="0,0,8,0">
                    <Button Content="Add New Rule..." Padding="12,6" Click="AddRule_Click"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="3" VerticalAlignment="Bottom">
                    <Button Content="Remove Selected" Padding="12,6" Foreground="#E74C3C" Click="RemoveRule_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Reset to WMO Defaults" Padding="14,8" Margin="0,0,8,0" Click="ResetDefaults_Click"/>
            <Button Content="Save &amp; Close" Style="{StaticResource PrimaryButton}" Padding="20,8" Click="SaveClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
