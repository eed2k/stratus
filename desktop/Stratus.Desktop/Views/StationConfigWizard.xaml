<Window x:Class="Stratus.Desktop.Views.StationConfigWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Station Configuration Wizard" Height="580" Width="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F4F8">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E293B" Padding="20,16">
            <StackPanel>
                <TextBlock Text="Station Configuration Wizard" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="StepIndicator" Text="Step 1 of 4 — Logger Connection" 
                           Foreground="#94A3B8" FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Step Content -->
        <TabControl Grid.Row="1" x:Name="WizardTabs" BorderThickness="0" Margin="0"
                    SelectionChanged="WizardTabs_SelectionChanged">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.ItemContainerStyle>

            <!-- Step 1: Logger Connection -->
            <TabItem>
                <ScrollViewer Padding="24,16" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Logger Connection" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Configure the communication parameters for your Campbell Scientific datalogger."
                                   Foreground="#64748B" TextWrapping="Wrap" Margin="0,4,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,8,8">
                                <TextBlock Text="COM Port:" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,4"/>
                                <ComboBox x:Name="PortCombo" Padding="6,4"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Baud Rate:" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,4"/>
                                <ComboBox x:Name="BaudCombo" Padding="6,4">
                                    <ComboBoxItem Content="9600"/>
                                    <ComboBoxItem Content="19200"/>
                                    <ComboBoxItem Content="38400"/>
                                    <ComboBoxItem Content="57600"/>
                                    <ComboBoxItem Content="115200" IsSelected="True"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,8,8">
                                <TextBlock Text="PakBus Address:" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,4"/>
                                <TextBox x:Name="AddressBox" Text="1" Padding="6,4"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,0,8">
                                <TextBlock Text="Security Code:" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,4"/>
                                <TextBox x:Name="SecurityCodeBox" Text="0" Padding="6,4"/>
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2" Margin="0,0,0,8">
                                <TextBlock Text="Station Name:" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,4"/>
                                <TextBox x:Name="StationNameBox" Padding="6,4"/>
                            </StackPanel>
                        </Grid>

                        <Button Content="Refresh COM Ports" Padding="12,6" Click="RefreshPorts_Click"
                                Background="#E2E8F0" BorderThickness="0" Cursor="Hand" Margin="0,8,0,0"
                                HorizontalAlignment="Left"/>

                        <Border x:Name="ConnectionStatus" Background="#F1F5F9" BorderBrush="#CBD5E1" 
                                BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,16,0,0">
                            <TextBlock x:Name="ConnectionStatusText" Text="Not connected" Foreground="#64748B"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Step 2: Clock Sync -->
            <TabItem>
                <ScrollViewer Padding="24,16" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Clock Synchronization" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Compare and synchronize the datalogger's internal clock with your PC."
                                   Foreground="#64748B" TextWrapping="Wrap" Margin="0,4,0,16"/>

                        <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="PC Time (UTC):" FontSize="11" Foreground="#64748B"/>
                                    <TextBlock x:Name="PcTimeText" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Logger Time:" FontSize="11" Foreground="#64748B"/>
                                    <TextBlock x:Name="LoggerTimeText" Text="—" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock x:Name="ClockDriftText" Text="" FontSize="13" Foreground="#D97306" 
                                   Margin="0,10,0,0" FontWeight="SemiBold"/>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="Read Logger Clock" Padding="14,6" Margin="0,0,8,0" Click="ReadClock_Click"
                                    Background="#2563EB" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
                            <Button Content="Sync Clock to PC" Padding="14,6" Click="SyncClock_Click"
                                    Background="#059669" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Step 3: Table Configuration -->
            <TabItem>
                <ScrollViewer Padding="24,16" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Data Table Configuration" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Discover and configure data tables on the connected datalogger."
                                   Foreground="#64748B" TextWrapping="Wrap" Margin="0,4,0,16"/>

                        <Button Content="Discover Tables" Padding="14,6" Click="DiscoverTables_Click"
                                Background="#2563EB" Foreground="White" BorderThickness="0" 
                                FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,10" HorizontalAlignment="Left"/>

                        <DataGrid x:Name="TablesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="White" BorderBrush="#CBD5E1" BorderThickness="1"
                                  RowHeight="28" ColumnHeaderHeight="32" MaxHeight="280">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#1E293B"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Padding" Value="6,4"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="11"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Table Name" Binding="{Binding Name}" Width="160"/>
                                <DataGridTextColumn Header="Fields" Binding="{Binding FieldCount}" Width="60"/>
                                <DataGridTextColumn Header="Record Interval" Binding="{Binding Interval}" Width="110"/>
                                <DataGridTextColumn Header="Field Names" Binding="{Binding FieldNames}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Step 4: Program Upload -->
            <TabItem>
                <ScrollViewer Padding="24,16" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Program Upload" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Upload a CRBasic program to the datalogger. Warning: this will stop the currently running program."
                                   Foreground="#DC2626" TextWrapping="Wrap" Margin="0,4,0,16"/>

                        <TextBlock Text="CRBasic Program File:" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ProgramPathBox" IsReadOnly="True" Padding="6,4" Background="#F8FAFC"/>
                            <Button Grid.Column="1" Content="Browse..." Padding="12,4" Margin="6,0,0,0" 
                                    Click="BrowseProgram_Click" Background="#E2E8F0" BorderThickness="0" Cursor="Hand"/>
                        </Grid>

                        <!-- Program preview -->
                        <TextBlock Text="Program Preview:" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,12,0,4"/>
                        <Border Background="#1E293B" CornerRadius="4" Padding="8" MaxHeight="200">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="ProgramPreview" FontFamily="Consolas" FontSize="11" 
                                           Foreground="#A5F3FC" TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </Border>

                        <TextBlock Text="⚠ Program upload via PakBus is not yet supported in this version. Use Campbell LoggerNet for program uploads."
                                   Foreground="#D97306" TextWrapping="Wrap" Margin="0,12,0,0" FontStyle="Italic"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Navigation Buttons -->
        <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="BackBtn" Content="← Back" Padding="16,8" Click="Back_Click"
                        Background="#E2E8F0" BorderThickness="0" Cursor="Hand" IsEnabled="False"/>
                <Button Grid.Column="2" x:Name="NextBtn" Content="Next →" Padding="16,8" Margin="0,0,8,0" Click="Next_Click"
                        Background="#2563EB" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
                <Button Grid.Column="3" Content="Close" Padding="16,8" Click="Close_Click"
                        Background="#E2E8F0" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Window>
