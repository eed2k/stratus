<Window x:Class="Stratus.Desktop.Views.ReportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Generate PDF Report" Height="500" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFFFFF">
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="PDF Report Generator" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="Generate comprehensive weather station reports with statistics, quality metrics, and summaries." 
                       TextWrapping="Wrap" Foreground="#1E293B" Margin="0,4,0,16"/>
            <Rectangle Height="2" Fill="#2563EB" HorizontalAlignment="Stretch"/>
        </StackPanel>

        <!-- Settings -->
        <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Report Title -->
                <TextBlock Text="Report Title:" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,4"/>
                <TextBox x:Name="TitleBox" Text="Monthly Weather Summary" Padding="8,6"
                         BorderBrush="#E2E8F0" FontSize="13"/>

                <!-- Date Range -->
                <TextBlock Text="Date Range:" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,16,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <DatePicker x:Name="FromDate" Grid.Column="0" VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="  to  " VerticalAlignment="Center" Foreground="#1E293B"/>
                    <DatePicker x:Name="ToDate" Grid.Column="2" VerticalContentAlignment="Center"/>
                </Grid>

                <!-- Quick Presets -->
                <TextBlock Text="Quick Presets:" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,16,0,4"/>
                <WrapPanel>
                    <Button Content="Last 7 Days" Padding="10,4" Margin="0,0,6,4" Click="LastWeek_Click"
                            Background="#E2E8F0" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="Last 30 Days" Padding="10,4" Margin="0,0,6,4" Click="LastMonth_Click"
                            Background="#E2E8F0" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="This Month" Padding="10,4" Margin="0,0,6,4" Click="ThisMonth_Click"
                            Background="#E2E8F0" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="Last 3 Months" Padding="10,4" Margin="0,0,6,4" Click="Last3Months_Click"
                            Background="#E2E8F0" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="This Year" Padding="10,4" Margin="0,0,6,4" Click="ThisYear_Click"
                            Background="#E2E8F0" BorderThickness="0" Cursor="Hand"/>
                </WrapPanel>

                <!-- Station Info -->
                <TextBlock Text="Station:" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,16,0,4"/>
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4" Padding="10">
                    <TextBlock x:Name="StationInfoText" Text="No station selected" Foreground="#1E293B"/>
                </Border>

                <TextBlock x:Name="RecordCountText" Text="" Foreground="#1E293B" FontSize="11" Margin="0,8,0,0"/>

                <!-- Status -->
                <TextBlock x:Name="StatusText" Text="" Foreground="#1D4ED8" FontWeight="SemiBold" Margin="0,12,0,0"/>
                <ProgressBar x:Name="ProgressBar" IsIndeterminate="False" Visibility="Collapsed" 
                             Height="4" Margin="0,6,0,0" Foreground="#1D4ED8"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Padding="20,8" Margin="0,0,8,0" Click="Cancel_Click"
                    Background="#E2E8F0" BorderThickness="0" FontSize="13" Cursor="Hand"/>
            <Button x:Name="GenerateBtn" Content="Generate Report" Padding="20,8" Click="Generate_Click"
                    Background="#1D4ED8" Foreground="White" BorderThickness="0" FontWeight="SemiBold"
                    FontSize="13" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
