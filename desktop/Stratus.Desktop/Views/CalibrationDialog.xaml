<Window x:Class="Stratus.Desktop.Views.CalibrationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calibration Management" Height="640" Width="820"
        WindowStartupLocation="CenterOwner"
        Background="#F0F4F8">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Sensor Calibration Management" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="Track calibration dates, apply correction coefficients, and manage compliance."
                       Foreground="#64748B" Margin="0,2,0,8"/>
            <Rectangle Height="2" Fill="#2563EB"/>
        </StackPanel>

        <!-- Calibration Profiles Grid -->
        <DataGrid Grid.Row="1" x:Name="CalGrid" Margin="0,8,0,0"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" CanUserSortColumns="True"
                  Background="White" BorderBrush="#CBD5E1" BorderThickness="1"
                  RowHeight="32" ColumnHeaderHeight="34"
                  SelectionChanged="CalGrid_SelectionChanged">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1E293B"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="11"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Sensor" Binding="{Binding DisplayName}" Width="120"/>
                <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="60"/>
                <DataGridTextColumn Header="Slope" Binding="{Binding Slope, StringFormat=F6}" Width="80"/>
                <DataGridTextColumn Header="Offset" Binding="{Binding Offset, StringFormat=F4}" Width="80"/>
                <DataGridTextColumn Header="Last Calibrated" Binding="{Binding LastCalibrationDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="Next Due" Binding="{Binding NextCalibrationDue, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="Calibrated By" Binding="{Binding CalibratedBy}" Width="100"/>
                <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsEnabled}" Width="50"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Overdue Warning -->
        <Border Grid.Row="2" x:Name="OverdueWarning" Background="#FEF2F2" BorderBrush="#EF4444" 
                BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,8,0,0" Visibility="Collapsed">
            <TextBlock x:Name="OverdueText" Foreground="#DC2626" FontWeight="SemiBold"/>
        </Border>

        <!-- Edit Form & Buttons -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Edit Panel -->
            <Border Grid.Column="0" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" 
                    CornerRadius="4" Padding="12" Margin="0,0,8,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,6,4">
                        <TextBlock Text="Sensor:" FontSize="10" Foreground="#64748B"/>
                        <ComboBox x:Name="SensorCombo" DisplayMemberPath="Display" Padding="4,3"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,6,4">
                        <TextBlock Text="Slope (multiplier):" FontSize="10" Foreground="#64748B"/>
                        <TextBox x:Name="SlopeBox" Text="1.000000" Padding="4,3"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,4">
                        <TextBlock Text="Offset:" FontSize="10" Foreground="#64748B"/>
                        <TextBox x:Name="OffsetBox" Text="0.0000" Padding="4,3"/>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,6,4">
                        <TextBlock Text="Calibrated By:" FontSize="10" Foreground="#64748B"/>
                        <TextBox x:Name="CalibratedByBox" Padding="4,3"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,6,4">
                        <TextBlock Text="Certificate Ref:" FontSize="10" Foreground="#64748B"/>
                        <TextBox x:Name="CertRefBox" Padding="4,3"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,0,0,4">
                        <TextBlock Text="Interval (days):" FontSize="10" Foreground="#64748B"/>
                        <TextBox x:Name="IntervalBox" Text="365" Padding="4,3"/>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2">
                        <TextBlock Text="Notes:" FontSize="10" Foreground="#64748B"/>
                        <TextBox x:Name="NotesBox" Padding="4,3" Height="40" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Action Buttons -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                <Button Content="Add/Update" Padding="16,8" Margin="0,0,0,6" Click="AddUpdate_Click"
                        Background="#2563EB" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
                <Button Content="Mark Calibrated" Padding="16,8" Margin="0,0,0,6" Click="MarkCalibrated_Click"
                        Background="#059669" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
                <Button Content="Remove" Padding="16,8" Margin="0,0,0,6" Click="Remove_Click"
                        Background="#DC2626" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
                <Button Content="Close" Padding="16,8" Click="Close_Click"
                        Background="#E2E8F0" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
