<Window x:Class="Stratus.Desktop.Views.AuditLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audit Trail" Height="580" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Audit Trail" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="Complete record of user actions for compliance and traceability."
                       Foreground="#1E293B" Margin="0,2,0,8"/>
            <Rectangle Height="2" Fill="#2563EB"/>
        </StackPanel>

        <!-- Filters -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="From:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#1E293B"/>
            <DatePicker Grid.Column="1" x:Name="AuditFrom" Width="130" Margin="0,0,10,0"/>
            <TextBlock Grid.Column="2" Text="To:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#1E293B"/>
            <DatePicker Grid.Column="3" x:Name="AuditTo" Width="130" Margin="0,0,10,0"/>
            <TextBlock Grid.Column="4" Text="Category:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#1E293B"/>
            <ComboBox Grid.Column="5" x:Name="CategoryFilter" Width="120" Margin="0,0,10,0"
                      SelectionChanged="CategoryFilter_Changed"/>
            <Button Grid.Column="6" Content="Refresh" Padding="14,6" Click="Refresh_Click"
                    Background="#1D4ED8" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
        </Grid>

        <!-- Audit Log Grid -->
        <DataGrid Grid.Row="2" x:Name="AuditGrid" Margin="0,10,0,0"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" CanUserSortColumns="True"
                  Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                  RowHeight="28" ColumnHeaderHeight="32">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1E293B"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Padding" Value="6,4"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="11"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Timestamp (UTC)" Binding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="140"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100"/>
                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="180"/>
                <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*"/>
                <DataGridTextColumn Header="User" Binding="{Binding User}" Width="100"/>
                <DataGridTextColumn Header="Station" Binding="{Binding StationId}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer Stats -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="EntryCountText" Foreground="#1E293B" FontSize="11" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Export CSV" Padding="14,6" Margin="0,0,6,0" Click="ExportCsv_Click"
                        Background="#E2E8F0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Close" Padding="14,6" Click="Close_Click"
                        Background="#E2E8F0" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
