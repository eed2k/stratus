<Window x:Class="Stratus.Desktop.Views.SetupWizardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stratus First-Time Setup" 
        Height="620" Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Style="{StaticResource StratusWindow}"
        Icon="/Assets/stratus.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,16">
            <StackPanel>
                <TextBlock Text="Welcome to Stratus" FontSize="22" FontWeight="SemiBold" 
                           Foreground="Black" FontFamily="{StaticResource HeaderFont}"/>
                <TextBlock Text="Weather Station Manager - First-Time Setup" 
                           FontSize="12" Foreground="#1E293B" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,12,20,0">
            <StackPanel>
                <!-- EULA Section -->
                <GroupBox Style="{StaticResource StratusGroupBox}" Header="Licence Agreement" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                            Stratus Weather Station Manager is proprietary software distributed under 
                            a commercial End User Licence Agreement (EULA). By using this software you 
                            agree to the terms of the licence. The software is provided "as is" without 
                            warranty of any kind.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                            © 2025-2026 Lukas Esterhuizen. All rights reserved.
                        </TextBlock>
                        <CheckBox x:Name="AcceptEulaCheckBox" Content="I accept the licence agreement" 
                                  FontSize="12" Checked="AcceptEula_Changed" Unchecked="AcceptEula_Changed"/>
                    </StackPanel>
                </GroupBox>

                <!-- Server Connection -->
                <GroupBox Style="{StaticResource StratusGroupBox}" Header="Server Connection" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                            The desktop app connects to your Stratus server to retrieve station data.
                            The default URL points to the production server.
                        </TextBlock>
                        <TextBlock Text="Server URL:" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox x:Name="ServerUrlBox" Style="{StaticResource StratusTextBox}" 
                                 Text="https://stratusweather.co.za" Margin="0,0,0,4"/>
                    </StackPanel>
                </GroupBox>

                <!-- License Key -->
                <GroupBox Style="{StaticResource StratusGroupBox}" Header="Licence Activation" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                            Enter your licence key to activate the software.
                        </TextBlock>
                        <TextBlock Text="Licence Key (optional):" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox x:Name="LicenseKeyBox" Style="{StaticResource StratusTextBox}" 
                                 FontFamily="Consolas" FontSize="13" CharacterCasing="Upper"
                                 MaxLength="24" Margin="0,0,0,4"
                                 ToolTip="Format: XXXX-XXXX-XXXX-XXXX-XXXX"/>
                        <TextBlock Text="Holder Name:" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox x:Name="HolderNameBox" Style="{StaticResource StratusTextBox}" Margin="0,0,0,4"/>
                        <TextBlock Text="Organisation:" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox x:Name="OrganizationBox" Style="{StaticResource StratusTextBox}" Margin="0,0,0,4"/>


                    </StackPanel>
                </GroupBox>

                <!-- Desktop Shortcut -->
                <GroupBox Style="{StaticResource StratusGroupBox}" Header="Options" Margin="0,0,0,12">
                    <StackPanel>
                        <CheckBox x:Name="CreateShortcutCheckBox" Content="Create desktop shortcut" 
                                  FontSize="12" IsChecked="True" Margin="0,0,0,4"/>
                        <CheckBox x:Name="CreateStartMenuCheckBox" Content="Create Start Menu shortcut" 
                                  FontSize="12" IsChecked="True"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="0,1,0,0" Padding="20,12">
            <StackPanel>
                <TextBlock x:Name="StatusText" Text="" FontSize="11" 
                           Foreground="{StaticResource DangerBrush}" Margin="0,0,0,8"
                           TextWrapping="Wrap" Visibility="Collapsed"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Style="{StaticResource SecondaryButton}" 
                            Click="Cancel_Click" Margin="0,0,8,0" Padding="20,8"/>
                    <Button x:Name="FinishButton" Content="Finish Setup" Style="{StaticResource PrimaryButton}" 
                            Click="Finish_Click" IsEnabled="False" Padding="20,8"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
