<Window x:Class="Stratus.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Stratus.Desktop.ViewModels"
        xmlns:controls="clr-namespace:Stratus.Desktop.Controls"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Stratus Weather Station Manager" 
        Height="768" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource StratusWindow}"
        Icon="/Assets/stratus.ico">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="{StaticResource MenuBarBrush}" Foreground="Black" FontSize="12" Padding="2">
            <MenuItem Header="_File">
                <MenuItem Header="_Connect to Server..." Command="{Binding ConnectCommand}"/>
                <MenuItem Header="_Export Data..." Command="{Binding ExportDataCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Station">
                <MenuItem Header="_Refresh Stations" Command="{Binding LoadStationsCommand}"/>
                <MenuItem Header="_Load Data" Command="{Binding LoadDataCommand}"/>
                <Separator/>
                <MenuItem Header="Start _Collection" Command="{Binding ToggleCollectionCommand}"/>
            </MenuItem>
            <MenuItem Header="_Database">
                <MenuItem Header="_Connect to PostgreSQL..." Click="ConnectDb_Click"/>
                <MenuItem Header="_Disconnect" Click="DisconnectDb_Click"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Generate Wind Rose" Click="GenerateWindRose_Click"/>
                <MenuItem Header="_Import TOA5/CSV for Wind Rose..." Click="ImportCsvWindRose_Click"/>
                <MenuItem Header="_Export Wind Rose PNG..." Click="ExportWindRosePng_Click"/>
                <Separator/>
                <MenuItem Header="_Licence Activation..." Click="License_Click"/>
                <MenuItem Header="_Settings" Click="Settings_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About Stratus" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Connection & Station List -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Connection Controls -->
                    <GroupBox DockPanel.Dock="Top" Style="{StaticResource StratusGroupBox}" Header="Server Connection" Margin="8,8,8,4">
                        <StackPanel>
                            <TextBlock Text="Server URL:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource StratusTextBox}" Margin="0,0,0,6"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Email:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Grid>
                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource StratusTextBox}" Margin="0,2,0,4"/>
                            
                            <TextBlock Text="Password:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <PasswordBox x:Name="PasswordBox" Padding="8,6" Margin="0,2,0,6"
                                         BorderBrush="{StaticResource BorderBrush}"/>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Connect" Style="{StaticResource PrimaryButton}" 
                                        Margin="0,0,4,0" Click="Login_Click"/>
                                <Ellipse Width="10" Height="10" 
                                         Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}, FallbackValue=Gray}"
                                         VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- Station List -->
                    <GroupBox Style="{StaticResource StratusGroupBox}" Header="Weather Stations" Margin="8,4,8,8">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Content="Refresh" Style="{StaticResource SecondaryButton}" 
                                        Command="{Binding LoadStationsCommand}" Padding="8,4" FontSize="11"/>
                                <TextBlock Text="{Binding Stations.Count, StringFormat='{}{0} stations'}" 
                                           VerticalAlignment="Center" Margin="8,0,0,0" 
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Stations}" 
                                     SelectedItem="{Binding SelectedStation}"
                                     BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                     Background="White">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4,4">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="8" Height="8" Margin="0,0,4,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="Gray"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Online">
                                                                    <Setter Property="Fill" Value="#27AE60"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Delayed">
                                                                    <Setter Property="Fill" Value="#F39C12"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Offline">
                                                                    <Setter Property="Fill" Value="#E74C3C"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="{Binding Status}" FontSize="10" 
                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <TextBlock Text=" | ID: " FontSize="10" 
                                                           Foreground="{StaticResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding Id}" FontSize="10" 
                                                           Foreground="{StaticResource TextMutedBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </GroupBox>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" Background="{StaticResource BorderBrush}" 
                          VerticalAlignment="Stretch" HorizontalAlignment="Center"/>

            <!-- Right Panel: Data View -->
            <TabControl Grid.Column="2" Background="{StaticResource BackgroundBrush}" 
                        BorderThickness="0" Padding="0" Margin="0">
                
                <!-- Station Monitor Tab -->
                <TabItem Header="  Monitor  " FontSize="12">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Station Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="{Binding SelectedStation.Name, FallbackValue='No Station Selected'}" 
                                       Style="{StaticResource SectionHeader}" FontSize="18" Margin="0,0,12,0"/>
                            <Button Content="{Binding IsCollecting, Converter={StaticResource BoolToCollectionText}, FallbackValue='Start Collection'}" 
                                    Style="{StaticResource PrimaryButton}" 
                                    Command="{Binding ToggleCollectionCommand}" Padding="12,6" FontSize="11"
                                    VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding TimeRanges}" 
                                      SelectedItem="{Binding SelectedTimeRange}"
                                      Margin="8,0,0,0" Padding="8,4" VerticalAlignment="Center"/>
                            <Button Content="Load" Style="{StaticResource SecondaryButton}" 
                                    Command="{Binding LoadDataCommand}" Padding="12,4" FontSize="11"
                                    Margin="4,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Current Values Panel -->
                        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" 
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" 
                                CornerRadius="4" Padding="12" Margin="0,0,0,12">
                            <WrapPanel>
                                <!-- Temperature -->
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Padding="12,4" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Temperature" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding LatestData.Temperature, StringFormat='{}{0:F1}', FallbackValue='--'}" 
                                                       Style="{StaticResource DataValueLabel}" FontSize="20"/>
                                            <TextBlock Text="°C" Style="{StaticResource DataUnitLabel}" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Humidity -->
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Padding="12,4" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Humidity" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding LatestData.Humidity, StringFormat='{}{0:F0}', FallbackValue='--'}" 
                                                       Style="{StaticResource DataValueLabel}" FontSize="20"/>
                                            <TextBlock Text="%" Style="{StaticResource DataUnitLabel}" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Pressure -->
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Padding="12,4" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Pressure" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding LatestData.Pressure, StringFormat='{}{0:F1}', FallbackValue='--'}" 
                                                       Style="{StaticResource DataValueLabel}" FontSize="20"/>
                                            <TextBlock Text="hPa" Style="{StaticResource DataUnitLabel}" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Wind -->
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Padding="12,4" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Wind" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding LatestData.WindSpeed, StringFormat='{}{0:F1}', FallbackValue='--'}" 
                                                       Style="{StaticResource DataValueLabel}" FontSize="20"/>
                                            <TextBlock Text="km/h" Style="{StaticResource DataUnitLabel}" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Solar -->
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Padding="12,4" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Solar" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding LatestData.SolarRadiation, StringFormat='{}{0:F0}', FallbackValue='--'}" 
                                                       Style="{StaticResource DataValueLabel}" FontSize="20"/>
                                            <TextBlock Text="W/m²" Style="{StaticResource DataUnitLabel}" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Rainfall -->
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Padding="12,4" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Rain" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding LatestData.Rainfall, StringFormat='{}{0:F1}', FallbackValue='--'}" 
                                                       Style="{StaticResource DataValueLabel}" FontSize="20"/>
                                            <TextBlock Text="mm" Style="{StaticResource DataUnitLabel}" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Battery -->
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Padding="12,4" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Battery" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding LatestData.BatteryVoltage, StringFormat='{}{0:F2}', FallbackValue='--'}" 
                                                       Style="{StaticResource DataValueLabel}" FontSize="20"/>
                                            <TextBlock Text="V" Style="{StaticResource DataUnitLabel}" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Water Level -->
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Padding="12,4" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Water Level" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding LatestData.WaterLevel, StringFormat='{}{0:F1}', FallbackValue='--'}" 
                                                       Style="{StaticResource DataValueLabel}" FontSize="20"/>
                                            <TextBlock Text="mm" Style="{StaticResource DataUnitLabel}" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Level Switch -->
                                <Border Padding="12,4">
                                    <StackPanel>
                                        <TextBlock Text="Level Switch" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding LatestData.LevelSwitch, StringFormat='{}{0:F0} mV', FallbackValue='--'}" 
                                                   Style="{StaticResource DataValueLabel}" FontSize="20"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </Border>

                        <!-- Data Grid -->
                        <DataGrid Grid.Row="2" ItemsSource="{Binding DataRecords}" 
                                  Style="{StaticResource StratusDataGrid}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  CanUserResizeColumns="True"
                                  CanUserReorderColumns="True"
                                  CanUserSortColumns="True"
                                  AutoGenerateColumns="False"
                                  FrozenColumnCount="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="1.5*" MinWidth="120" CanUserResize="True"/>
                                <DataGridTextColumn Header="Temp" Binding="{Binding Temperature, StringFormat='{}{0:F1}'}" Width="*" MinWidth="50" CanUserResize="True"/>
                                <DataGridTextColumn Header="RH%" Binding="{Binding Humidity, StringFormat='{}{0:F0}'}" Width="*" MinWidth="40" CanUserResize="True"/>
                                <DataGridTextColumn Header="Press" Binding="{Binding Pressure, StringFormat='{}{0:F1}'}" Width="*" MinWidth="50" CanUserResize="True"/>
                                <DataGridTextColumn Header="Wind" Binding="{Binding WindSpeed, StringFormat='{}{0:F1}'}" Width="*" MinWidth="45" CanUserResize="True"/>
                                <DataGridTextColumn Header="Dir" Binding="{Binding WindDirection, StringFormat='{}{0:F0}'}" Width="*" MinWidth="35" CanUserResize="True"/>
                                <DataGridTextColumn Header="Gust" Binding="{Binding WindGust, StringFormat='{}{0:F1}'}" Width="*" MinWidth="45" CanUserResize="True"/>
                                <DataGridTextColumn Header="Rain" Binding="{Binding Rainfall, StringFormat='{}{0:F1}'}" Width="*" MinWidth="45" CanUserResize="True"/>
                                <DataGridTextColumn Header="Solar" Binding="{Binding SolarRadiation, StringFormat='{}{0:F0}'}" Width="*" MinWidth="45" CanUserResize="True"/>
                                <DataGridTextColumn Header="UV" Binding="{Binding UvIndex, StringFormat='{}{0:F1}'}" Width="0.7*" MinWidth="30" CanUserResize="True"/>
                                <DataGridTextColumn Header="SoilT" Binding="{Binding SoilTemperature, StringFormat='{}{0:F1}'}" Width="*" MinWidth="40" CanUserResize="True"/>
                                <DataGridTextColumn Header="SoilM" Binding="{Binding SoilMoisture, StringFormat='{}{0:F1}'}" Width="*" MinWidth="40" CanUserResize="True"/>
                                <DataGridTextColumn Header="Batt" Binding="{Binding BatteryVoltage, StringFormat='{}{0:F2}'}" Width="*" MinWidth="40" CanUserResize="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Charts Tab -->
                <TabItem Header="  Charts  " FontSize="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12">
                        <StackPanel>
                            <TextBlock Text="Charts auto-show for parameters with data. Load data first, then switch time range." 
                                       FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                            <!-- Temperature + Dew Point -->
                            <GroupBox Header="Temperature / Dew Point (°C)" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasTemperature, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding TemperatureSeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- Humidity -->
                            <GroupBox Header="Humidity (%)" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasHumidity, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding HumiditySeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- Pressure -->
                            <GroupBox Header="Barometric Pressure (hPa)" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasPressure, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding PressureSeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- Dew Point (standalone, only if no temperature) -->
                            <GroupBox Header="Dew Point (°C)" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasDewPoint, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding DewPointSeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- Wind Speed + Gust -->
                            <GroupBox Header="Wind Speed / Gust (km/h)" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasWind, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding WindSeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- Wind Direction -->
                            <GroupBox Header="Wind Direction (°)" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasWindDirection, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding WindDirectionSeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- Rainfall -->
                            <GroupBox Header="Rainfall (mm)" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasRainfall, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding RainfallSeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- Solar Radiation -->
                            <GroupBox Header="Solar Radiation (W/m²)" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasSolar, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding SolarSeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- UV Index -->
                            <GroupBox Header="UV Index" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasUvIndex, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding UvIndexSeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- Evapotranspiration -->
                            <GroupBox Header="Evapotranspiration — ETo (mm/day)" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasEto, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding EtoSeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- Soil Temperature + Moisture -->
                            <GroupBox Header="Soil (Temperature / Moisture)" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasSoil, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding SoilSeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- Air Quality (PM2.5 + PM10) -->
                            <GroupBox Header="Air Quality — PM2.5 / PM10 (µg/m³)" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasAirQuality, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding AirQualitySeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- Battery / Charger / Panel -->
                            <GroupBox Header="Battery / Charger / Panel Temperature" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasBattery, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding BatterySeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- Water Level -->
                            <GroupBox Header="Water Level (mm)" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasWaterLevel, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding WaterLevelSeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- Temperature Switch / Level Switch -->
                            <GroupBox Header="Switches (Temp / Level)" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasSwitch, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding SwitchSeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- Lightning -->
                            <GroupBox Header="Lightning (strikes)" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasLightning, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding LightningSeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- MPPT Charger 1 — Power -->
                            <GroupBox Header="MPPT Charger 1 — Solar Power (W)" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasMpptPower, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding MpptPowerSeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- MPPT Charger 1 — Voltages -->
                            <GroupBox Header="MPPT Charger 1 — Voltages (V)" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasMpptVoltage, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding MpptVoltageSeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- MPPT Charger 1 — Currents -->
                            <GroupBox Header="MPPT Charger 1 — Currents (mA)" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasMpptCurrent, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding MpptCurrentSeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- MPPT Charger 2 — Power -->
                            <GroupBox Header="MPPT Charger 2 — Solar Power (W)" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasMppt2Power, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding Mppt2PowerSeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>

                            <!-- MPPT Charger 2 — Voltages -->
                            <GroupBox Header="MPPT Charger 2 — Voltages (V)" Style="{StaticResource StratusGroupBox}" Margin="0,0,0,8"
                                      Visibility="{Binding HasMppt2Voltage, Converter={StaticResource BoolToVis}}">
                                <lvc:CartesianChart Height="220" Series="{Binding Mppt2VoltageSeries}" XAxes="{Binding ChartXAxes}" TooltipPosition="Top" ZoomMode="X"/>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Data Log Tab -->
                <TabItem Header="  Activity Log  " FontSize="12">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="System Activity Log" 
                                   Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <ListBox Grid.Row="1" ItemsSource="{Binding LogMessages}" 
                                 BorderBrush="{StaticResource BorderBrush}" Background="White"
                                 FontFamily="{StaticResource MonoFont}" FontSize="11">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="NoWrap"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>

                <!-- Export Tab -->
                <TabItem Header="  Export  " FontSize="12">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Data Export" 
                                   Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        
                        <GroupBox Grid.Row="1" Style="{StaticResource StratusGroupBox}" Header="Export Settings">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Station:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding SelectedStation.Name, FallbackValue='Select a station'}" 
                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Records in DB:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding RecordCount, StringFormat='{}{0:N0}'}" 
                                               FontWeight="SemiBold" VerticalAlignment="Center"
                                               FontFamily="{StaticResource MonoFont}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Format: TOA5 (Campbell Scientific compatible)" 
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Output: Documents\Stratus\" FontSize="11" 
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                <Button Content="Export 30-Day Data" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ExportDataCommand}" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </TabItem>

                <!-- Wind Rose Tab -->
                <TabItem Header="  Wind Rose  " FontSize="12">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Wind Rose Controls -->
                        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Sector Angle:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                                    <Slider x:Name="AngleSlider" Minimum="5" Maximum="60" Value="15"
                                            TickFrequency="5" IsSnapToTickEnabled="True"
                                            Width="200" VerticalAlignment="Center"
                                            ValueChanged="AngleSlider_ValueChanged"/>
                                    <TextBlock x:Name="AngleLabel" Text="15°" VerticalAlignment="Center"
                                               Margin="8,0,0,0" FontSize="12" FontWeight="SemiBold" MinWidth="30"/>
                                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="16,0"/>
                                    <TextBlock Text="Station:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                                    <TextBlock Text="{Binding SelectedStation.Name, FallbackValue='No station selected'}"
                                               VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12" Margin="0,0,16,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Generate from Station Data" Style="{StaticResource PrimaryButton}"
                                            Click="GenerateWindRose_Click" Padding="12,6" FontSize="11" Margin="0,0,8,0"/>
                                    <Button Content="Import TOA5/CSV..." Style="{StaticResource SecondaryButton}"
                                            Click="ImportCsvWindRose_Click" Padding="12,6" FontSize="11" Margin="0,0,8,0"/>
                                    <Button Content="Export PNG..." Style="{StaticResource SecondaryButton}"
                                            Click="ExportWindRosePng_Click" Padding="12,6" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Wind Rose Display -->
                        <TabControl Grid.Row="1" x:Name="WindRoseTabControl" BorderThickness="1"
                                    BorderBrush="{StaticResource BorderBrush}" Background="White">
                            <TabItem Header="  24h  " FontSize="11">
                                <controls:WindRoseControl x:Name="WindRose24h" Margin="4"/>
                            </TabItem>
                            <TabItem Header="  1d  " FontSize="11">
                                <controls:WindRoseControl x:Name="WindRose1d" Margin="4"/>
                            </TabItem>
                            <TabItem Header="  3d  " FontSize="11">
                                <controls:WindRoseControl x:Name="WindRose3d" Margin="4"/>
                            </TabItem>
                            <TabItem Header="  7d  " FontSize="11">
                                <controls:WindRoseControl x:Name="WindRose7d" Margin="4"/>
                            </TabItem>
                            <TabItem Header="  30d  " FontSize="11">
                                <controls:WindRoseControl x:Name="WindRose30d" Margin="4"/>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Style="{StaticResource StratusStatusBar}" Padding="8,4">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Foreground="Black"/>
            </StatusBarItem>
            <Separator Background="#CCCCCC"/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,4,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#E74C3C"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="#27AE60"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionStatus}" Foreground="Black"/>
                </StackPanel>
            </StatusBarItem>
            <Separator Background="#CCCCCC"/>
            <StatusBarItem>
                <TextBlock Foreground="Black">
                    <Run Text="Licence: "/>
                    <Run Text="{Binding LicenseStatus, Mode=OneWay}"/>
                </TextBlock>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="Stratus Desktop v1.1.0 | Lukas Esterhuizen" Foreground="#777777" FontSize="10"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
