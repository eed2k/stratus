<Window x:Class="Stratus.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Stratus.Desktop.ViewModels"
        Title="Stratus Weather Station Manager" 
        Height="768" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource StratusWindow}"
        Icon="/Assets/stratus.ico">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="{StaticResource PrimaryBrush}" Foreground="White" FontSize="12" Padding="2">
            <MenuItem Header="_File">
                <MenuItem Header="_Connect to Server..." Command="{Binding ConnectCommand}"/>
                <MenuItem Header="_Export Data..." Command="{Binding ExportDataCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Station">
                <MenuItem Header="_Refresh Stations" Command="{Binding LoadStationsCommand}"/>
                <MenuItem Header="_Load Data" Command="{Binding LoadDataCommand}"/>
                <Separator/>
                <MenuItem Header="Start _Collection" Command="{Binding ToggleCollectionCommand}"/>
            </MenuItem>
            <MenuItem Header="_Database">
                <MenuItem Header="_Connect to PostgreSQL..." Click="ConnectDb_Click"/>
                <MenuItem Header="_Disconnect" Click="DisconnectDb_Click"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_License Activation..." Click="License_Click"/>
                <MenuItem Header="_Settings" Click="Settings_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About Stratus" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Connection & Station List -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Connection Controls -->
                    <GroupBox DockPanel.Dock="Top" Style="{StaticResource StratusGroupBox}" Header="Server Connection" Margin="8,8,8,4">
                        <StackPanel>
                            <TextBlock Text="Server URL:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource StratusTextBox}" Margin="0,0,0,6"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Email:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Grid>
                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource StratusTextBox}" Margin="0,2,0,4"/>
                            
                            <TextBlock Text="Password:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <PasswordBox x:Name="PasswordBox" Padding="8,6" Margin="0,2,0,6"
                                         BorderBrush="{StaticResource BorderBrush}"/>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Connect" Style="{StaticResource PrimaryButton}" 
                                        Margin="0,0,4,0" Click="Login_Click"/>
                                <Ellipse Width="10" Height="10" 
                                         Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}, FallbackValue=Gray}"
                                         VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- Station List -->
                    <GroupBox Style="{StaticResource StratusGroupBox}" Header="Weather Stations" Margin="8,4,8,8">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Content="Refresh" Style="{StaticResource SecondaryButton}" 
                                        Command="{Binding LoadStationsCommand}" Padding="8,4" FontSize="11"/>
                                <TextBlock Text="{Binding Stations.Count, StringFormat='{}{0} stations'}" 
                                           VerticalAlignment="Center" Margin="8,0,0,0" 
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Stations}" 
                                     SelectedItem="{Binding SelectedStation}"
                                     BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                     Background="White">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4,4">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="8" Height="8" Margin="0,0,4,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="Gray"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Online">
                                                                    <Setter Property="Fill" Value="#27AE60"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Delayed">
                                                                    <Setter Property="Fill" Value="#F39C12"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Offline">
                                                                    <Setter Property="Fill" Value="#E74C3C"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="{Binding Status}" FontSize="10" 
                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <TextBlock Text=" | ID: " FontSize="10" 
                                                           Foreground="{StaticResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding Id}" FontSize="10" 
                                                           Foreground="{StaticResource TextMutedBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </GroupBox>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" Background="{StaticResource BorderBrush}" 
                          VerticalAlignment="Stretch" HorizontalAlignment="Center"/>

            <!-- Right Panel: Data View -->
            <TabControl Grid.Column="2" Background="{StaticResource BackgroundBrush}" 
                        BorderThickness="0" Padding="0" Margin="0">
                
                <!-- Station Monitor Tab -->
                <TabItem Header="  Monitor  " FontSize="12">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Station Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="{Binding SelectedStation.Name, FallbackValue='No Station Selected'}" 
                                       Style="{StaticResource SectionHeader}" FontSize="18" Margin="0,0,12,0"/>
                            <Button Content="{Binding IsCollecting, Converter={StaticResource BoolToCollectionText}, FallbackValue='Start Collection'}" 
                                    Style="{StaticResource PrimaryButton}" 
                                    Command="{Binding ToggleCollectionCommand}" Padding="12,6" FontSize="11"
                                    VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding TimeRanges}" 
                                      SelectedItem="{Binding SelectedTimeRange}"
                                      Margin="8,0,0,0" Padding="8,4" VerticalAlignment="Center"/>
                            <Button Content="Load" Style="{StaticResource SecondaryButton}" 
                                    Command="{Binding LoadDataCommand}" Padding="12,4" FontSize="11"
                                    Margin="4,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Current Values Panel -->
                        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" 
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" 
                                CornerRadius="4" Padding="12" Margin="0,0,0,12">
                            <WrapPanel>
                                <!-- Temperature -->
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Padding="12,4" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Temperature" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding LatestData.Temperature, StringFormat='{}{0:F1}', FallbackValue='--'}" 
                                                       Style="{StaticResource DataValueLabel}" FontSize="20"/>
                                            <TextBlock Text="°C" Style="{StaticResource DataUnitLabel}" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Humidity -->
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Padding="12,4" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Humidity" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding LatestData.Humidity, StringFormat='{}{0:F0}', FallbackValue='--'}" 
                                                       Style="{StaticResource DataValueLabel}" FontSize="20"/>
                                            <TextBlock Text="%" Style="{StaticResource DataUnitLabel}" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Pressure -->
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Padding="12,4" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Pressure" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding LatestData.Pressure, StringFormat='{}{0:F1}', FallbackValue='--'}" 
                                                       Style="{StaticResource DataValueLabel}" FontSize="20"/>
                                            <TextBlock Text="hPa" Style="{StaticResource DataUnitLabel}" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Wind -->
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Padding="12,4" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Wind" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding LatestData.WindSpeed, StringFormat='{}{0:F1}', FallbackValue='--'}" 
                                                       Style="{StaticResource DataValueLabel}" FontSize="20"/>
                                            <TextBlock Text="km/h" Style="{StaticResource DataUnitLabel}" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Solar -->
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Padding="12,4" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Solar" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding LatestData.SolarRadiation, StringFormat='{}{0:F0}', FallbackValue='--'}" 
                                                       Style="{StaticResource DataValueLabel}" FontSize="20"/>
                                            <TextBlock Text="W/m²" Style="{StaticResource DataUnitLabel}" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Rainfall -->
                                <Border Padding="12,4">
                                    <StackPanel>
                                        <TextBlock Text="Rain" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding LatestData.Rainfall, StringFormat='{}{0:F1}', FallbackValue='--'}" 
                                                       Style="{StaticResource DataValueLabel}" FontSize="20"/>
                                            <TextBlock Text="mm" Style="{StaticResource DataUnitLabel}" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </Border>

                        <!-- Data Grid -->
                        <DataGrid Grid.Row="2" ItemsSource="{Binding DataRecords}" 
                                  Style="{StaticResource StratusDataGrid}"
                                  VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="160"/>
                                <DataGridTextColumn Header="Temp (°C)" Binding="{Binding Temperature, StringFormat='{}{0:F1}'}" Width="80"/>
                                <DataGridTextColumn Header="RH (%)" Binding="{Binding Humidity, StringFormat='{}{0:F0}'}" Width="70"/>
                                <DataGridTextColumn Header="Press (hPa)" Binding="{Binding Pressure, StringFormat='{}{0:F1}'}" Width="90"/>
                                <DataGridTextColumn Header="Wind (km/h)" Binding="{Binding WindSpeed, StringFormat='{}{0:F1}'}" Width="90"/>
                                <DataGridTextColumn Header="Dir (°)" Binding="{Binding WindDirection, StringFormat='{}{0:F0}'}" Width="70"/>
                                <DataGridTextColumn Header="Gust (km/h)" Binding="{Binding WindGust, StringFormat='{}{0:F1}'}" Width="90"/>
                                <DataGridTextColumn Header="Rain (mm)" Binding="{Binding Rainfall, StringFormat='{}{0:F1}'}" Width="80"/>
                                <DataGridTextColumn Header="Solar (W/m²)" Binding="{Binding SolarRadiation, StringFormat='{}{0:F0}'}" Width="90"/>
                                <DataGridTextColumn Header="UV" Binding="{Binding UvIndex, StringFormat='{}{0:F1}'}" Width="60"/>
                                <DataGridTextColumn Header="Soil T (°C)" Binding="{Binding SoilTemperature, StringFormat='{}{0:F1}'}" Width="80"/>
                                <DataGridTextColumn Header="Soil M (%)" Binding="{Binding SoilMoisture, StringFormat='{}{0:F1}'}" Width="80"/>
                                <DataGridTextColumn Header="Batt (V)" Binding="{Binding BatteryVoltage, StringFormat='{}{0:F2}'}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Data Log Tab -->
                <TabItem Header="  Activity Log  " FontSize="12">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="System Activity Log" 
                                   Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <ListBox Grid.Row="1" ItemsSource="{Binding LogMessages}" 
                                 BorderBrush="{StaticResource BorderBrush}" Background="White"
                                 FontFamily="{StaticResource MonoFont}" FontSize="11">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="NoWrap"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>

                <!-- Export Tab -->
                <TabItem Header="  Export  " FontSize="12">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Data Export" 
                                   Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        
                        <GroupBox Grid.Row="1" Style="{StaticResource StratusGroupBox}" Header="Export Settings">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Station:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding SelectedStation.Name, FallbackValue='Select a station'}" 
                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Records in DB:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding RecordCount, StringFormat='{}{0:N0}'}" 
                                               FontWeight="SemiBold" VerticalAlignment="Center"
                                               FontFamily="{StaticResource MonoFont}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Format: TOA5 (Campbell Scientific compatible)" 
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Output: Documents\Stratus\" FontSize="11" 
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                <Button Content="Export 30-Day Data" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ExportDataCommand}" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Style="{StaticResource StratusStatusBar}" Padding="8,4">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Foreground="White"/>
            </StatusBarItem>
            <Separator Background="#3A5A80"/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,4,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#E74C3C"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="#27AE60"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionStatus}" Foreground="White"/>
                </StackPanel>
            </StatusBarItem>
            <Separator Background="#3A5A80"/>
            <StatusBarItem>
                <TextBlock Foreground="White">
                    <Run Text="License: "/>
                    <Run Text="{Binding LicenseStatus, Mode=OneWay}"/>
                </TextBlock>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="Stratus Desktop v1.2.0 | Lukas Esterhuizen" Foreground="#8899AA" FontSize="10"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
