<Window x:Class="Stratus.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Stratus.Desktop.ViewModels"
        xmlns:controls="clr-namespace:Stratus.Desktop.Controls"
        Title="Stratus Weather Station Manager" 
        Height="768" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource StratusWindow}"
        Icon="/Assets/stratus.ico">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar — Dark RTDM Instrument Panel -->
        <Menu Grid.Row="0" Background="{StaticResource MenuBarBrush}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Padding="2">
            <MenuItem Header="_File">
                <MenuItem Header="_Connect to Server..." Command="{Binding ConnectCommand}"/>
                <MenuItem Header="_Export Data..." Command="{Binding ExportDataCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Station">
                <MenuItem Header="_Refresh Stations" Command="{Binding LoadStationsCommand}"/>
                <MenuItem Header="_Load Data" Command="{Binding LoadDataCommand}"/>
                <Separator/>
                <MenuItem Header="Start _Collection" Command="{Binding ToggleCollectionCommand}"/>
            </MenuItem>
            <MenuItem Header="_Database">
                <MenuItem Header="_Connect to PostgreSQL..." Click="ConnectDb_Click"/>
                <MenuItem Header="_Disconnect" Click="DisconnectDb_Click"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Generate Wind Rose" Click="GenerateWindRose_Click"/>
                <MenuItem Header="_Import TOA5/CSV for Wind Rose..." Click="ImportCsvWindRose_Click"/>
                <MenuItem Header="_Export Wind Rose PNG..." Click="ExportWindRosePng_Click"/>
                <Separator/>
                <MenuItem Header="Export All _Charts as PNG..." Click="ExportCharts_Click"/>
                <Separator/>
                <MenuItem Header="_Licence Activation..." Click="License_Click"/>
                <MenuItem Header="_Settings" Click="Settings_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About Stratus" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Connection & Station List — Dark -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Connection Controls -->
                    <GroupBox DockPanel.Dock="Top" Style="{StaticResource StratusGroupBox}" Header="Server Connection" Margin="8,8,8,4">
                        <StackPanel>
                            <TextBlock Text="Server URL:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource StratusTextBox}" Margin="0,0,0,6"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Email:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Grid>
                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource StratusTextBox}" Margin="0,2,0,4"/>
                            
                            <TextBlock Text="Password:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <PasswordBox x:Name="PasswordBox" Padding="8,6" Margin="0,2,0,6"
                                         BorderBrush="{StaticResource BorderBrush}"/>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Connect" Style="{StaticResource PrimaryButton}" 
                                        Margin="0,0,4,0" Click="Login_Click"/>
                                <Ellipse Width="10" Height="10" 
                                         Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}, FallbackValue=Gray}"
                                         VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- Station List — Dark -->
                    <GroupBox Style="{StaticResource StratusGroupBox}" Header="Weather Stations" Margin="8,4,8,8">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Content="Refresh" Style="{StaticResource SecondaryButton}" 
                                        Command="{Binding LoadStationsCommand}" Padding="8,4" FontSize="11"/>
                                <TextBlock Text="{Binding Stations.Count, StringFormat='{}{0} stations'}" 
                                           VerticalAlignment="Center" Margin="8,0,0,0" 
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Stations}" 
                                     SelectedItem="{Binding SelectedStation}"
                                     BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                     Background="{StaticResource SurfaceLightBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4,4">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="8" Height="8" Margin="0,0,4,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="Gray"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Online">
                                                                    <Setter Property="Fill" Value="#27AE60"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Delayed">
                                                                    <Setter Property="Fill" Value="#F39C12"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Offline">
                                                                    <Setter Property="Fill" Value="#E74C3C"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="{Binding Status}" FontSize="10" 
                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <TextBlock Text=" | ID: " FontSize="10" 
                                                           Foreground="{StaticResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding Id}" FontSize="10" 
                                                           Foreground="{StaticResource TextMutedBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </GroupBox>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" Background="{StaticResource BorderBrush}" 
                          VerticalAlignment="Stretch" HorizontalAlignment="Center"/>

            <!-- Right Panel: Data View -->
            <TabControl Grid.Column="2" Background="{StaticResource BackgroundBrush}" 
                        BorderThickness="0" Padding="0" Margin="0">
                
                <!-- Station Monitor Tab — RTDM Instrument Panel -->
                <TabItem Header="  Monitor  " FontSize="12">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Station Header — Dark -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="{Binding SelectedStation.Name, FallbackValue='No Station Selected'}" 
                                       Style="{StaticResource SectionHeader}" FontSize="18" Margin="0,0,12,0"/>
                            <Button Content="{Binding IsCollecting, Converter={StaticResource BoolToCollectionText}, FallbackValue='Start Collection'}" 
                                    Style="{StaticResource PrimaryButton}" 
                                    Command="{Binding ToggleCollectionCommand}" Padding="12,6" FontSize="11"
                                    VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding TimeRanges}" 
                                      SelectedItem="{Binding SelectedTimeRange}"
                                      Margin="8,0,0,0" Padding="8,4" VerticalAlignment="Center"/>
                            <Button Content="Load" Style="{StaticResource SecondaryButton}" 
                                    Command="{Binding LoadDataCommand}" Padding="12,4" FontSize="11"
                                    Margin="4,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- ═══════ RTDM Gauge Panel ═══════ -->
                        <Border Grid.Row="1" Background="{StaticResource BackgroundBrush}" 
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" 
                                CornerRadius="4" Padding="8" Margin="0,0,0,12">
                            <UniformGrid Rows="2" Columns="5">
                                <!-- Temperature Gauge -->
                                <controls:GaugeControl Value="{Binding LatestData.Temperature}" 
                                    MinValue="-10" MaxValue="50" Unit="°C" Label="Temperature"
                                    ValueFormat="F1" AccentColor="#FF6B6B"
                                    Width="160" Height="160" Margin="4"/>
                                <!-- Humidity Gauge -->
                                <controls:GaugeControl Value="{Binding LatestData.Humidity}" 
                                    MinValue="0" MaxValue="100" Unit="%" Label="Humidity"
                                    ValueFormat="F0" AccentColor="#4FC3F7"
                                    Width="160" Height="160" Margin="4"/>
                                <!-- Pressure Gauge -->
                                <controls:GaugeControl Value="{Binding LatestData.Pressure}" 
                                    MinValue="950" MaxValue="1050" Unit="hPa" Label="Pressure"
                                    ValueFormat="F1" AccentColor="#80DEEA"
                                    Width="160" Height="160" Margin="4"/>
                                <!-- Wind Speed Gauge -->
                                <controls:GaugeControl Value="{Binding LatestData.WindSpeed}" 
                                    MinValue="0" MaxValue="120" Unit="km/h" Label="Wind Speed"
                                    ValueFormat="F1" AccentColor="#69F0AE"
                                    Width="160" Height="160" Margin="4"/>
                                <!-- Solar Radiation Gauge -->
                                <controls:GaugeControl Value="{Binding LatestData.SolarRadiation}" 
                                    MinValue="0" MaxValue="1200" Unit="W/m²" Label="Solar"
                                    ValueFormat="F0" AccentColor="#FFD54F"
                                    Width="160" Height="160" Margin="4"/>
                                <!-- Rainfall Gauge -->
                                <controls:GaugeControl Value="{Binding LatestData.Rainfall}" 
                                    MinValue="0" MaxValue="50" Unit="mm" Label="Rainfall"
                                    ValueFormat="F1" AccentColor="#40C4FF"
                                    Width="160" Height="160" Margin="4"/>
                                <!-- Dew Point Gauge -->
                                <controls:GaugeControl Value="{Binding LatestData.DewPoint}" 
                                    MinValue="-10" MaxValue="35" Unit="°C" Label="Dew Point"
                                    ValueFormat="F1" AccentColor="#BB86FC"
                                    Width="160" Height="160" Margin="4"/>
                                <!-- ETo Gauge -->
                                <controls:GaugeControl Value="{Binding LatestData.Eto}" 
                                    MinValue="0" MaxValue="15" Unit="mm" Label="ETo"
                                    ValueFormat="F2" AccentColor="#26DEC8"
                                    Width="160" Height="160" Margin="4"/>
                                <!-- Battery Gauge -->
                                <controls:GaugeControl Value="{Binding LatestData.BatteryVoltage}" 
                                    MinValue="0" MaxValue="15" Unit="V" Label="Battery"
                                    ValueFormat="F2" AccentColor="#69F0AE"
                                    Width="160" Height="160" Margin="4"/>
                                <!-- Water Level Gauge -->
                                <controls:GaugeControl Value="{Binding LatestData.WaterLevel}" 
                                    MinValue="0" MaxValue="500" Unit="mm" Label="Water Level"
                                    ValueFormat="F1" AccentColor="#40C4FF"
                                    Width="160" Height="160" Margin="4"/>
                            </UniformGrid>
                        </Border>

                        <!-- Data Grid -->
                        <DataGrid Grid.Row="2" ItemsSource="{Binding DataRecords}" 
                                  Style="{StaticResource StratusDataGrid}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  CanUserResizeColumns="True"
                                  CanUserReorderColumns="True"
                                  CanUserSortColumns="True"
                                  AutoGenerateColumns="False"
                                  FrozenColumnCount="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="1.5*" MinWidth="120" CanUserResize="True"/>
                                <DataGridTextColumn Header="Temp" Binding="{Binding Temperature, StringFormat='{}{0:F1}'}" Width="*" MinWidth="50" CanUserResize="True"/>
                                <DataGridTextColumn Header="RH%" Binding="{Binding Humidity, StringFormat='{}{0:F0}'}" Width="*" MinWidth="40" CanUserResize="True"/>
                                <DataGridTextColumn Header="Press" Binding="{Binding Pressure, StringFormat='{}{0:F1}'}" Width="*" MinWidth="50" CanUserResize="True"/>
                                <DataGridTextColumn Header="Wind" Binding="{Binding WindSpeed, StringFormat='{}{0:F1}'}" Width="*" MinWidth="45" CanUserResize="True"/>
                                <DataGridTextColumn Header="Dir" Binding="{Binding WindDirection, StringFormat='{}{0:F0}'}" Width="*" MinWidth="35" CanUserResize="True"/>
                                <DataGridTextColumn Header="Gust" Binding="{Binding WindGust, StringFormat='{}{0:F1}'}" Width="*" MinWidth="45" CanUserResize="True"/>
                                <DataGridTextColumn Header="Rain" Binding="{Binding Rainfall, StringFormat='{}{0:F1}'}" Width="*" MinWidth="45" CanUserResize="True"/>
                                <DataGridTextColumn Header="Solar" Binding="{Binding SolarRadiation, StringFormat='{}{0:F0}'}" Width="*" MinWidth="45" CanUserResize="True"/>
                                <DataGridTextColumn Header="UV" Binding="{Binding UvIndex, StringFormat='{}{0:F1}'}" Width="0.7*" MinWidth="30" CanUserResize="True"/>
                                <DataGridTextColumn Header="DewPt" Binding="{Binding DewPoint, StringFormat='{}{0:F1}'}" Width="*" MinWidth="40" CanUserResize="True"/>
                                <DataGridTextColumn Header="ETo" Binding="{Binding Eto, StringFormat='{}{0:F2}'}" Width="*" MinWidth="40" CanUserResize="True"/>
                                <DataGridTextColumn Header="SoilT" Binding="{Binding SoilTemperature, StringFormat='{}{0:F1}'}" Width="*" MinWidth="40" CanUserResize="True"/>
                                <DataGridTextColumn Header="SoilM" Binding="{Binding SoilMoisture, StringFormat='{}{0:F1}'}" Width="*" MinWidth="40" CanUserResize="True"/>
                                <DataGridTextColumn Header="Batt" Binding="{Binding BatteryVoltage, StringFormat='{}{0:F2}'}" Width="*" MinWidth="40" CanUserResize="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Charts Tab -->
                <TabItem Header="  Charts  " FontSize="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Chart toolbar -->
                        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Charts auto-show for parameters with data. Change time range to reload." 
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" 
                                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <Button Content="Export All Charts as PNG..." Style="{StaticResource SecondaryButton}"
                                        Click="ExportCharts_Click" Padding="12,4" FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <!-- ═══════ RTDM 2-Column Chart Grid ═══════ -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="8">
                            <WrapPanel x:Name="ChartsStackPanel" Orientation="Horizontal">

                                <!-- Temperature + Dew Point + Min/Max -->
                                <Border Margin="4" Visibility="{Binding HasTemperature, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding TemperatureImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Humidity -->
                                <Border Margin="4" Visibility="{Binding HasHumidity, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding HumidityImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Pressure + Sea Level -->
                                <Border Margin="4" Visibility="{Binding HasPressure, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding PressureImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Dew Point standalone -->
                                <Border Margin="4" Visibility="{Binding HasDewPoint, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding DewPointImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Wind Speed + Gust -->
                                <Border Margin="4" Visibility="{Binding HasWind, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding WindImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Wind Direction -->
                                <Border Margin="4" Visibility="{Binding HasWindDirection, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding WindDirectionImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Wind Power -->
                                <Border Margin="4" Visibility="{Binding HasWindPower, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding WindPowerImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Rainfall + 24h -->
                                <Border Margin="4" Visibility="{Binding HasRainfall, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding RainfallImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Solar Radiation + Max -->
                                <Border Margin="4" Visibility="{Binding HasSolar, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding SolarImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- UV Index -->
                                <Border Margin="4" Visibility="{Binding HasUvIndex, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding UvIndexImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Evapotranspiration + 24h -->
                                <Border Margin="4" Visibility="{Binding HasEto, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding EtoImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Soil + Leaf Wetness -->
                                <Border Margin="4" Visibility="{Binding HasSoil, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding SoilImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Air Quality PM1/2.5/10 -->
                                <Border Margin="4" Visibility="{Binding HasAirQuality, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding AirQualityImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- CO₂ & TVOC -->
                                <Border Margin="4" Visibility="{Binding HasCo2Tvoc, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding Co2TvocImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Air Density -->
                                <Border Margin="4" Visibility="{Binding HasAirDensity, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding AirDensityImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Battery / Charger / Panel -->
                                <Border Margin="4" Visibility="{Binding HasBattery, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding BatteryImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Water Level -->
                                <Border Margin="4" Visibility="{Binding HasWaterLevel, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding WaterLevelImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Switches -->
                                <Border Margin="4" Visibility="{Binding HasSwitch, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding SwitchImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Lightning -->
                                <Border Margin="4" Visibility="{Binding HasLightning, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding LightningImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- MPPT 1 Power -->
                                <Border Margin="4" Visibility="{Binding HasMpptPower, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding MpptPowerImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- MPPT 1 Voltages -->
                                <Border Margin="4" Visibility="{Binding HasMpptVoltage, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding MpptVoltageImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- MPPT 1 Currents -->
                                <Border Margin="4" Visibility="{Binding HasMpptCurrent, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding MpptCurrentImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- MPPT 2 Power -->
                                <Border Margin="4" Visibility="{Binding HasMppt2Power, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding Mppt2PowerImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- MPPT 2 Voltages -->
                                <Border Margin="4" Visibility="{Binding HasMppt2Voltage, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding Mppt2VoltageImage}" Width="780" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                            </WrapPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <!-- Data Log Tab -->
                <TabItem Header="  Activity Log  " FontSize="12">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="System Activity Log" 
                                   Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <ListBox Grid.Row="1" ItemsSource="{Binding LogMessages}" 
                                 BorderBrush="{StaticResource BorderBrush}" 
                                 Background="White"
                                 FontFamily="{StaticResource MonoFont}" FontSize="11">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="NoWrap"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>

                <!-- Export Tab -->
                <TabItem Header="  Export  " FontSize="12">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Data Export" 
                                   Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        
                        <GroupBox Grid.Row="1" Style="{StaticResource StratusGroupBox}" Header="Export Settings">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Station:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding SelectedStation.Name, FallbackValue='Select a station'}" 
                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Records in DB:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding RecordCount, StringFormat='{}{0:N0}'}" 
                                               FontWeight="SemiBold" VerticalAlignment="Center"
                                               FontFamily="{StaticResource MonoFont}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Format: TOA5 (Campbell Scientific compatible)" 
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Output: Documents\Stratus\" FontSize="11" 
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                <Button Content="Export 30-Day Data" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ExportDataCommand}" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </TabItem>

                <!-- Wind Rose Tab -->
                <TabItem Header="  Wind Rose  " FontSize="12">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Wind Rose Controls -->
                        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Sector Angle:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                                    <Slider x:Name="AngleSlider" Minimum="5" Maximum="60" Value="15"
                                            TickFrequency="5" IsSnapToTickEnabled="True"
                                            Width="200" VerticalAlignment="Center"
                                            ValueChanged="AngleSlider_ValueChanged"/>
                                    <TextBlock x:Name="AngleLabel" Text="15°" VerticalAlignment="Center"
                                               Margin="8,0,0,0" FontSize="12" FontWeight="SemiBold" MinWidth="30"/>
                                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="16,0"/>
                                    <TextBlock Text="Station:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                                    <TextBlock Text="{Binding SelectedStation.Name, FallbackValue='No station selected'}"
                                               VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12" Margin="0,0,16,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Generate from Station Data" Style="{StaticResource PrimaryButton}"
                                            Click="GenerateWindRose_Click" Padding="12,6" FontSize="11" Margin="0,0,8,0"/>
                                    <Button Content="Import TOA5/CSV..." Style="{StaticResource SecondaryButton}"
                                            Click="ImportCsvWindRose_Click" Padding="12,6" FontSize="11" Margin="0,0,8,0"/>
                                    <Button Content="Export PNG..." Style="{StaticResource SecondaryButton}"
                                            Click="ExportWindRosePng_Click" Padding="12,6" FontSize="11" Margin="0,0,8,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Wind Rose Display -->
                        <TabControl Grid.Row="1" x:Name="WindRoseTabControl" BorderThickness="1"
                                    BorderBrush="{StaticResource BorderBrush}" 
                                    Background="White">
                            <TabItem Header="  24h  " FontSize="11">
                                <controls:WindRoseControl x:Name="WindRose24h" Margin="4"/>
                            </TabItem>
                            <TabItem Header="  1d  " FontSize="11">
                                <controls:WindRoseControl x:Name="WindRose1d" Margin="4"/>
                            </TabItem>
                            <TabItem Header="  3d  " FontSize="11">
                                <controls:WindRoseControl x:Name="WindRose3d" Margin="4"/>
                            </TabItem>
                            <TabItem Header="  7d  " FontSize="11">
                                <controls:WindRoseControl x:Name="WindRose7d" Margin="4"/>
                            </TabItem>
                            <TabItem Header="  30d  " FontSize="11">
                                <controls:WindRoseControl x:Name="WindRose30d" Margin="4"/>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Style="{StaticResource StratusStatusBar}" Padding="8,4">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextPrimaryBrush}"/>
            </StatusBarItem>
            <Separator Background="{StaticResource BorderBrush}"/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,4,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#E74C3C"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="#27AE60"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionStatus}" Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>
            </StatusBarItem>
            <Separator Background="{StaticResource BorderBrush}"/>
            <StatusBarItem>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="Licence: "/>
                    <Run Text="{Binding LicenseStatus, Mode=OneWay}"/>
                </TextBlock>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="Stratus Desktop v1.1.0 | Lukas Esterhuizen" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
