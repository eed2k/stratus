<Window x:Class="Stratus.Desktop.Views.StationEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Station Editor — Stratus" Height="520" Width="480"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource StratusWindow}"
        Icon="/Assets/stratus.ico">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Station Metadata" FontSize="16" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Station Name:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
            <TextBox x:Name="NameBox" Style="{StaticResource StratusTextBox}" Padding="8,6" Margin="0,0,0,10"/>

            <TextBlock Text="Description:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
            <TextBox x:Name="DescBox" Style="{StaticResource StratusTextBox}" Padding="8,6" 
                     TextWrapping="Wrap" AcceptsReturn="True" Height="60" Margin="0,0,0,10"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Latitude:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                    <TextBox x:Name="LatBox" Style="{StaticResource StratusTextBox}" Padding="8,6"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Longitude:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                    <TextBox x:Name="LonBox" Style="{StaticResource StratusTextBox}" Padding="8,6"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="Elevation (m):" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,2"/>
            <TextBox x:Name="ElevBox" Style="{StaticResource StratusTextBox}" Padding="8,6" Margin="0,0,0,10"/>

            <TextBlock Text="Datalogger Model:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
            <ComboBox x:Name="LoggerCombo" Padding="8,4" Margin="0,0,0,10">
                <ComboBoxItem Content="CR1000X" IsSelected="True"/>
                <ComboBoxItem Content="CR1000"/>
                <ComboBoxItem Content="CR6"/>
                <ComboBoxItem Content="CR300"/>
                <ComboBoxItem Content="CR310"/>
                <ComboBoxItem Content="CR800"/>
                <ComboBoxItem Content="CR850"/>
                <ComboBoxItem Content="CR3000"/>
                <ComboBoxItem Content="Other"/>
            </ComboBox>

            <TextBlock Text="Protocol:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
            <ComboBox x:Name="ProtocolCombo" Padding="8,4" Margin="0,0,0,10">
                <ComboBoxItem Content="api" IsSelected="True"/>
                <ComboBoxItem Content="dropbox"/>
                <ComboBoxItem Content="ftp"/>
                <ComboBoxItem Content="pakbus"/>
                <ComboBoxItem Content="serial"/>
            </ComboBox>

            <TextBlock Text="Time Zone:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
            <TextBox x:Name="TzBox" Text="Africa/Johannesburg" Style="{StaticResource StratusTextBox}" Padding="8,6"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" Style="{StaticResource PrimaryButton}"
                    Click="Save_Click" Padding="20,8" Margin="0,0,8,0"/>
            <Button Content="Delete Station" Background="#1E293B" Foreground="White"
                    BorderThickness="0" Padding="20,8" Cursor="Hand" Margin="0,0,8,0"
                    Click="Delete_Click"/>
            <Button Content="Cancel" Background="#E2E8F0" BorderThickness="0" 
                    Padding="20,8" Cursor="Hand" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
