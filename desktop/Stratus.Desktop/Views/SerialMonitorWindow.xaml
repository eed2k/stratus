<Window x:Class="Stratus.Desktop.Views.SerialMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Serial Monitor — Stratus PakBus" 
        Height="600" Width="850"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource StratusWindow}">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <Border Grid.Row="0" Background="#F0F0F0" CornerRadius="4" Padding="8" Margin="0,0,0,8">
            <WrapPanel>
                <!-- Port Selection -->
                <TextBlock Text="Port:" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="SemiBold"/>
                <ComboBox x:Name="PortCombo" Width="100" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <Button Content="↻" Click="RefreshPorts_Click" ToolTip="Refresh ports" Width="28" Height="28"
                        VerticalAlignment="Center" Margin="0,0,12,0"/>

                <!-- Baud Rate -->
                <TextBlock Text="Baud:" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="SemiBold"/>
                <ComboBox x:Name="BaudCombo" Width="90" Margin="0,0,12,0" VerticalAlignment="Center">
                    <ComboBoxItem Content="9600"/>
                    <ComboBoxItem Content="19200"/>
                    <ComboBoxItem Content="38400"/>
                    <ComboBoxItem Content="57600"/>
                    <ComboBoxItem Content="115200" IsSelected="True"/>
                </ComboBox>

                <!-- Logger Address -->
                <TextBlock Text="Addr:" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="SemiBold"
                           ToolTip="PakBus logger address (default: 1)"/>
                <TextBox x:Name="AddressBox" Width="50" Text="1" VerticalAlignment="Center" Margin="0,0,12,0"
                         TextAlignment="Center"/>

                <!-- Poll Interval -->
                <TextBlock Text="Poll:" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="SemiBold"/>
                <ComboBox x:Name="IntervalCombo" Width="100" Margin="0,0,12,0" VerticalAlignment="Center">
                    <ComboBoxItem Content="5 sec" Tag="5"/>
                    <ComboBoxItem Content="10 sec" Tag="10"/>
                    <ComboBoxItem Content="15 sec" Tag="15"/>
                    <ComboBoxItem Content="30 sec" Tag="30" IsSelected="True"/>
                    <ComboBoxItem Content="1 min" Tag="60"/>
                    <ComboBoxItem Content="2 min" Tag="120"/>
                    <ComboBoxItem Content="5 min" Tag="300"/>
                    <ComboBoxItem Content="10 min" Tag="600"/>
                    <ComboBoxItem Content="15 min" Tag="900"/>
                    <ComboBoxItem Content="30 min" Tag="1800"/>
                </ComboBox>

                <!-- Buttons -->
                <Button x:Name="ConnectButton" Content="Connect" Click="Connect_Click" 
                        Style="{StaticResource PrimaryButton}" Margin="0,0,4,0" Padding="12,4" VerticalAlignment="Center"/>
                <Button x:Name="DisconnectButton" Content="Disconnect" Click="Disconnect_Click" 
                        Style="{StaticResource SecondaryButton}" IsEnabled="False" Margin="0,0,4,0" Padding="12,4" VerticalAlignment="Center"/>
                <Button x:Name="PollOnceButton" Content="Poll Now" Click="PollOnce_Click" 
                        Style="{StaticResource SecondaryButton}" IsEnabled="False" Margin="0,0,4,0" Padding="12,4" VerticalAlignment="Center"/>
                <Button x:Name="StartPollingButton" Content="Start Polling" Click="StartPolling_Click" 
                        Style="{StaticResource PrimaryButton}" IsEnabled="False" Margin="0,0,4,0" Padding="12,4" VerticalAlignment="Center"/>
                <Button x:Name="StopPollingButton" Content="Stop Polling" Click="StopPolling_Click" 
                        Style="{StaticResource SecondaryButton}" IsEnabled="False" Padding="12,4" VerticalAlignment="Center"/>
            </WrapPanel>
        </Border>

        <!-- ── Monitor Log ── -->
        <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- Log output -->
                <TextBox x:Name="MonitorOutput" Grid.Column="0" 
                         IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="11" Background="#1E1E1E" Foreground="#D4D4D4"
                         BorderThickness="0" Padding="8"/>

                <!-- Latest Values Panel -->
                <Border Grid.Column="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Live Values" FontWeight="Bold" FontSize="13"
                                   Background="#F0F0F0" Padding="8,6"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="LiveValuesPanel" Margin="8">
                                <TextBlock x:Name="LiveTimestamp" Text="—" FontFamily="Consolas" FontSize="11" 
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                                <TextBlock Text="Temperature" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="LiveTemp" Text="— °C" FontFamily="Consolas" FontSize="16" FontWeight="Bold" Margin="0,0,0,6"/>

                                <TextBlock Text="Humidity" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="LiveHumidity" Text="— %" FontFamily="Consolas" FontSize="16" FontWeight="Bold" Margin="0,0,0,6"/>

                                <TextBlock Text="Pressure" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="LivePressure" Text="— hPa" FontFamily="Consolas" FontSize="16" FontWeight="Bold" Margin="0,0,0,6"/>

                                <TextBlock Text="Wind Speed" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="LiveWind" Text="— km/h" FontFamily="Consolas" FontSize="16" FontWeight="Bold" Margin="0,0,0,6"/>

                                <TextBlock Text="Wind Direction" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="LiveWindDir" Text="— °" FontFamily="Consolas" FontSize="14" Margin="0,0,0,6"/>

                                <TextBlock Text="Rainfall" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="LiveRain" Text="— mm" FontFamily="Consolas" FontSize="14" Margin="0,0,0,6"/>

                                <TextBlock Text="Solar Radiation" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="LiveSolar" Text="— W/m²" FontFamily="Consolas" FontSize="14" Margin="0,0,0,6"/>

                                <TextBlock Text="Battery" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="LiveBattery" Text="— V" FontFamily="Consolas" FontSize="14" Margin="0,0,0,6"/>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── Status Bar ── -->
        <Border Grid.Row="2" Background="#F0F0F0" Padding="8,4" Margin="0,4,0,0" CornerRadius="2">
            <DockPanel>
                <Ellipse x:Name="StatusIndicator" Width="10" Height="10" Fill="Gray" 
                         DockPanel.Dock="Left" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="Not connected" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Run x:Name="PacketCount" Text="0" FontWeight="SemiBold"/> 
                    <Run Text="packets"/>
                </TextBlock>
                <Button Content="Clear" Click="Clear_Click" DockPanel.Dock="Right" 
                        Padding="8,2" Margin="8,0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
