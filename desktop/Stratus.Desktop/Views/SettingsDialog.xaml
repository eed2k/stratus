<Window x:Class="Stratus.Desktop.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" 
        Height="460" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource StratusWindow}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Application Settings" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Server Settings -->
                <GroupBox Style="{StaticResource StratusGroupBox}" Header="Server Connection" Margin="0,0,0,12">
                    <StackPanel Margin="4">
                        <TextBlock Text="Server URL:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBox x:Name="ServerUrlBox" Style="{StaticResource StratusTextBox}" Margin="0,0,0,8"/>
                        <TextBlock Text="API Timeout (seconds):" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBox x:Name="TimeoutBox" Style="{StaticResource StratusTextBox}" Width="80" HorizontalAlignment="Left"/>
                    </StackPanel>
                </GroupBox>

                <!-- Data Acquisition -->
                <GroupBox Style="{StaticResource StratusGroupBox}" Header="Data Acquisition" Margin="0,0,0,12">
                    <StackPanel Margin="4">
                        <TextBlock Text="Polling Interval (seconds):" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBox x:Name="PollIntervalBox" Style="{StaticResource StratusTextBox}" Width="80" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                        <CheckBox x:Name="AutoConnectCheck" Content="Auto-connect on startup" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- Export Settings -->
                <GroupBox Style="{StaticResource StratusGroupBox}" Header="Export Defaults" Margin="0,0,0,12">
                    <StackPanel Margin="4">
                        <TextBlock Text="Export Format:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <ComboBox x:Name="ExportFormatBox" Width="200" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <ComboBoxItem Content="TOA5 (Campbell Scientific)" IsSelected="True"/>
                            <ComboBoxItem Content="CSV (Standard)"/>
                        </ComboBox>
                        <TextBlock Text="Default Export Range:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <ComboBox x:Name="ExportRangeBox" Width="200" HorizontalAlignment="Left">
                            <ComboBoxItem Content="7 days"/>
                            <ComboBoxItem Content="30 days" IsSelected="True"/>
                            <ComboBoxItem Content="90 days"/>
                            <ComboBoxItem Content="All data"/>
                        </ComboBox>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" Style="{StaticResource PrimaryButton}" Padding="20,8" Click="Save_Click" Margin="0,0,8,0"/>
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Padding="20,8" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
