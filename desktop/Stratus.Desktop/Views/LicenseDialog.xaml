<Window x:Class="Stratus.Desktop.Views.LicenseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Licence Information - Stratus" 
        Height="460" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource StratusWindow}">
    <Grid Margin="20">
        <!-- ===== ACTIVE LICENCE VIEW (read-only) ===== -->
        <StackPanel x:Name="ActiveLicensePanel" Visibility="Collapsed">
            <TextBlock Text="Licence Information" Style="{StaticResource SectionHeader}" Margin="0,0,0,16"/>

            <Border Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Licence Key:" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ActiveKeyText" FontFamily="Consolas" FontSize="13" Margin="0,0,0,10"
                               Foreground="{StaticResource PrimaryBrush}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Licence Type:" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ActiveTypeText" FontSize="12" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Holder Name:" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ActiveHolderText" FontSize="12" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Organisation:" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ActiveOrgText" FontSize="12" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Max Stations:" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="ActiveStationsText" FontSize="12" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Expires:" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,0"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="ActiveExpiryText" FontSize="12" Margin="0,0,0,0"/>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="Change Licence" Style="{StaticResource SecondaryButton}" 
                        Click="ChangeLicense_Click" Margin="0,0,8,0"/>
                <Button Content="Close" Style="{StaticResource SecondaryButton}" 
                        Click="Close_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- ===== ACTIVATION VIEW (editable) ===== -->
        <Grid x:Name="ActivationPanel" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Licence Activation" Style="{StaticResource SectionHeader}"/>

            <!-- Current Licence Info -->
            <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Current Licence" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                    <TextBlock x:Name="LicenseTypeText" Text="No licence activated" FontSize="11" 
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="LicenseExpiryText" Text="" FontSize="11" 
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="2" Text="Licence Key:" FontSize="11" Margin="0,0,0,4"/>
            <TextBox Grid.Row="3" x:Name="LicenseKeyBox" 
                     Style="{StaticResource StratusTextBox}" 
                     Text="" FontFamily="Consolas" FontSize="14" CharacterCasing="Upper"
                     MaxLength="24" Margin="0,0,0,8"
                     ToolTip="Format: XXXX-XXXX-XXXX-XXXX-XXXX"/>

            <TextBlock Grid.Row="4" Text="Licence Holder:" FontSize="11" Margin="0,0,0,4"/>
            <TextBox Grid.Row="5" x:Name="HolderNameBox" 
                     Style="{StaticResource StratusTextBox}" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="6" Text="Organisation:" FontSize="11" Margin="0,0,0,4"/>
            <TextBox Grid.Row="7" x:Name="OrganizationBox" 
                     Style="{StaticResource StratusTextBox}" VerticalAlignment="Top"/>

            <StackPanel Grid.Row="8" Margin="0,16,0,0">
                <TextBlock x:Name="ActivationStatus" Text="" FontSize="11" 
                           Margin="0,0,0,8" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Activate" Style="{StaticResource PrimaryButton}" 
                            Click="Activate_Click" Margin="0,0,8,0"/>
                    <Button Content="Close" Style="{StaticResource SecondaryButton}" 
                            Click="Close_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
