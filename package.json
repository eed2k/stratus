{
    "name": "weather-station-app",
    "version": "1.0.0",
    "description": "A weather station application that integrates with research-grade weather stations and displays weather data including wind roses.",
    "main": "index.js",
    "scripts": {
        "build:functions": "esbuild serverless-src/functions/*.ts --bundle --platform=node --target=node14 --outdir=netlify/functions",
        "build": "npm run build:functions && npm run build:client",
        "build:client": "cd client && npm ci && npm run build",
        "dev": "cd client && npm run dev"
    },
    "dependencies": {
        "@netlify/functions": "^5.1.1",
        "@vitejs/plugin-react": "^5.1.2",
        "axios": "^0.21.1",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.5",
        "dotenv": "^8.2.0",
        "esbuild": "^0.27.2",
        "express": "^4.17.1",
        "jsonwebtoken": "^9.0.3",
        "pg": "^8.16.3",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "socket.io": "^4.0.0",
        "vite": "^7.3.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.8",
        "@types/jest": "^26.0.0",
        "@types/node": "^14.14.31",
        "jest": "^26.6.3",
        "ts-node": "^9.1.1",
        "typescript": "^4.1.2"
    },
    "author": "Frederick Le Roux",
    "license": "MIT"
}
